# =============================================
#  HabitPulz Backend — Environment Variables
#  Copy this file to .env and fill in values
# =============================================

# Gemini API Key
# Get your free key at: https://aistudio.google.com/app/apikey
# Key starts with "AIza..."
GEMINI_API_KEY=AIzaYour-Gemini-API-Key-Here

# Gemini Model
# Options:
#   gemini-1.5-flash   → fast, free tier, recommended
#   gemini-1.5-pro     → more powerful, higher quota
#   gemini-1.0-pro     → older stable model
GEMINI_MODEL=gemini-1.5-flash

# Server Port
PORT=3000
